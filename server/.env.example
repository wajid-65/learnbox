# ============================================================
#  Server Environment Variables – EXAMPLE TEMPLATE
#  Copy this file to .env and fill in your real values.
#  NEVER commit the real .env file to Git.
# ============================================================

# MongoDB connection string (use MongoDB Atlas URL for production)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/department_knowledge_hub

# Session secret – use a long random string in production
SESSION_SECRET=your_super_secret_key_here

# Server port
PORT=5000

# Set to "production" on live server, "development" locally
NODE_ENV=development

# Comma-separated list of allowed frontend origins (for CORS)
# Example: CORS_ORIGINS=https://your-admin.netlify.app,https://your-student.netlify.app
CORS_ORIGINS=http://localhost:4200,http://localhost:5173
